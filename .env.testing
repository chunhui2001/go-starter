### [app settings]
GIN_ENV=testing
APP_NAME=go-starter
APP_PORT=0.0.0.0:8080

### [websocket]
WSS_HOST=ws://localhost:8080
WSS_PREFIX=/ws1

### [redis]
REDIS_Enable=true
REDIS_Host=127.0.0.1:6379
REDIS_Password=Cc
REDIS_MaxIdle=30
REDIS_MaxActive=30
REDIS_IdleTimeout=200s

### session settings
COOKIE_ENABLE=true
COOKIE_NAME=__GIN_SESSION
COOKIE_SECRET=__my_cookie_secret
