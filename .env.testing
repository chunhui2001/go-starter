### [app settings]
GIN_ENV=testing
APP_NAME=go-starter
APP_PORT=0.0.0.0:8080

### [logger settings]
LOG_OUTPUT=console,kafka
LOG_FILE_PATH=/tmp/go-starter
LOG_KAFKA_SERVER=127.0.0.1:9092
LOG_KAFKA_TOPIC=app_log_go-starter

### [web pages]
WEB_Enable=true
WEB_ROOT=views
WEB_MASTER=layouts/master
WEB_Extension=.html

### [websocket]
WSS_HOST=ws://localhost:8080
WSS_PREFIX=/ws1

### [redis]
REDIS_Mode=1
REDIS_Host=127.0.0.1:6479
# REDIS_URL=redis://<user>:<pass>@localhost:6379/<db>
# REDIS_Password=Cc
REDIS_DataBase=0
REDIS_MaxIdle=30
REDIS_MaxActive=30
REDIS_IdleTimeout=200s
### just redis sentinel mode have master name
REDIS_MASTER_NAME=__my_redis_master_name_here__
REDIS_ADDRS=127.0.0.1:6381,127.0.0.1:6382,127.0.0.1:6383,127.0.0.4:6384,127.0.0.1:6385
### To route commands by latency or randomly, enable one of the following.
REDIS_RouteByLatency=false 			
REDIS_RouteRandomly=true

### [kafka]
KAFKA_SERVER=

### cookie session settings
COOKIE_ENABLE=false
COOKIE_NAME=__GIN_SESSION
COOKIE_SECRET=__my_cookie_secret
COOKIE_MaxAge=600 # 10 minutes
